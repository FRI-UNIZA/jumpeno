@namespace Jumpeno.Client.Components

@inherits Component

<div class="user-login-form">
    <Heading1 Class="login-heading" Size="TEXT_SIZE.L">@I18N.T("Login")</Heading1>
    <div class="login-inputs">
        <Input ViewModel="VMEmail" Size="INPUT_SIZE.M" Align="INPUT_ALIGN.CENTER" Autocomplete HideLabel />
        <Input ViewModel="VMPassword" Size="INPUT_SIZE.M" Align="INPUT_ALIGN.CENTER" HideLabel />
    </div>
    <Button Size="BUTTON_SIZE.M" OnClick="Login">
        <Text>@I18N.T("Log in")</Text>
    </Button>
    <Paragraph Size="TEXT_SIZE.S" Class="register-block">
        @I18N.T("Not a user?")&nbsp;
        <Link Size="TEXT_SIZE.S" NoWrap OnClick="() => VM.Show(LOGIN_FORM.REGISTER)" Underline>
            @I18N.T("Register")
        </Link>
    </Paragraph>
    <Link Size="TEXT_SIZE.S" NoWrap OnClick="() => VM.Show(LOGIN_FORM.ADMIN)">
        <AntIcon Type="safety-certificate" Theme="outline" Class="icon-admin"/>&nbsp;@I18N.T("I am admin")&nbsp;
    </Link>
</div>
